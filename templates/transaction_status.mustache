{{!
    @template paygw_payu/transaction_status

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * none

    Example context (json):
    {
        "success": true,
        "failed": false,
        "redirecturl": "https://example.com/course/view.php?id=2",
    }

}}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 col-sm-12">
            <div class="card shadow-sm">
                <div class="card-body text-center p-5">
                    {{#success}}
                        <div class="mb-4 text-success">
                            {{#pix}} i/valid, core, {{#str}}paymentsuccessful,paygw_payu{{/str}} {{/pix}}
                        </div>
                        <p class="text-muted mb-4">
                            {{#str}} paymentsuccessful, paygw_payu {{/str}}
                        </p>
                    {{/success}}
                    {{#failed}}
                        <div class="mb-4 text-danger">
                            {{#pix}} i/invalid, core, {{#str}}paymentfailed,paygw_payu{{/str}} {{/pix}}
                        </div>
                        <p class="text-muted mb-4">
                            {{#str}} paymentfailed, paygw_payu {{/str}}
                        </p>                        
                    {{/failed}}

                    {{#redirecturl}}
                        <a
                            href="{{redirecturl}}"
                            class="btn btn-primary btn-lg">
                            Continue
                        </a>
                    {{/redirecturl}}
                </div>
            </div>
        </div>
    </div>
</div>