<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="payment/gateway/payu/db" VERSION="20260710" COMMENT="XMLDB file for Moodle payment/gateway/payu"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="paygw_payu" COMMENT="Payu Payment related information">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="paymentid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="id from payments table"/>
        <FIELD NAME="txnid" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" COMMENT="unique transaction id for payment, reference id"/>
        <FIELD NAME="hash" TYPE="char" LENGTH="200" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="mihpayid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="status" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Status of order"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="paymentid" TYPE="foreign-unique" FIELDS="paymentid" REFTABLE="payments" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="txnid_uix" UNIQUE="true" FIELDS="txnid"/>
      </INDEXES>      
    </TABLE>
    <TABLE NAME="paygw_payu_log" COMMENT="Stores request and response logs">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="txnid" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="direction" TYPE="char" LENGTH="20" NOTNULL="true"/>
        <FIELD NAME="endpoint" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="requestheaders" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="requestbody" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="responsecode" TYPE="int" LENGTH="4" NOTNULL="false"/>
        <FIELD NAME="responsebody" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="errormessage" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="transactionid_ix" UNIQUE="false" FIELDS="txnid"/>
        <INDEX NAME="direction_ix" UNIQUE="false" FIELDS="direction"/>
        <INDEX NAME="timecreated_ix" UNIQUE="false" FIELDS="timecreated"/>
      </INDEXES>
    </TABLE>    
  </TABLES>
</XMLDB>